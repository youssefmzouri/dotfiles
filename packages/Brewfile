# Brewfile — CLI tools installed via Homebrew on BOTH macOS and Linux.
# Apply with: brew bundle --file=packages/Brewfile
# Keep this list cross-platform (no casks here — see Brewfile.darwin).

tap "hashicorp/tap"

brew "git"
brew "gh"          # GitHub CLI
brew "mise"        # runtime version manager (node/java/python/...)
brew "fzf"         # fuzzy finder
brew "ripgrep"     # fast grep (rg)
brew "fd"          # fast find
brew "bat"         # cat with syntax highlighting
brew "eza"         # modern ls
brew "zoxide"      # smarter cd
brew "jq"          # JSON processor
brew "awscli"      # AWS CLI
brew "hashicorp/tap/terraform"  # infrastructure as code
brew "zsh"
